EOF
elif [ "$1" = "get" ] && [ "$2" = "mcp" ]; then
  cat <<'EOF'
NAME      CONFIG                                             UPDATED   UPDATING   DEGRADED
master    rendered-master-dummy1234567890abcdef1234567890ab   True      False      False
