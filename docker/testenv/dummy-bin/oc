#!/bin/sh
if [ "$1" = "get" ] && [ "$2" = "nodes" ]; then
  cat <<'EOF'
NAME               STATUS   ROLES           AGE   VERSION
dummy-node1        Ready    control-plane   10d   v1.30.2
dummy-node2        Ready    worker          10d   v1.30.2
EOF
elif [ "$1" = "get" ] && [ "$2" = "pods" ]; then
  cat <<'EOF'
NAMESPACE     NAME                READY   STATUS    RESTARTS   AGE
kube-system   dummy-pod-abc123    1/1     Running   0          10d
default       dummy-app-xyz789    1/1     Running   0          2d
