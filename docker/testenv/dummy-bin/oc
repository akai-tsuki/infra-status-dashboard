elif [ "$1" = "get" ] && [ "$2" = "co" ]; then
  cat <<'EOF'
NAME                                       VERSION      AVAILABLE   PROGRESSING   DEGRADED   SINCE
dummy-authentication                       4.16.0       True        False         False      10d
